DATABASE_URL="postgresql://many_zac:many_zac@localhost:5432/many_zac?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="1d"
PORT=3001

# 32 raw bytes, base64-encoded. Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY="change-me-32-bytes-base64-encoded=="

# Meta (Instagram/Messenger) app credentials
META_APP_ID=""
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN="change-me"

# Comma-separated hostnames the external_request runtime node is allowed to call.
# Unset/empty means every external_request node fails (fail closed - see execution-runner.service.ts).
EXTERNAL_REQUEST_ALLOWED_HOSTS=""
